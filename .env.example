# Base de données PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sensante?schema=public"

# Groq API — L'Oracle
# Créer un compte sur https://console.groq.com
# Modèle recommandé : llama-3.3-70b-versatile
GROQ_API_KEY="votre-cle-groq-ici"

# NextAuth.js — Le Bouclier
# Générer un secret avec : openssl rand -base64 32
NEXTAUTH_SECRET="un-secret-aleatoire-genere-avec-openssl"
# En développement local
NEXTAUTH_URL="http://localhost:3000"
# En production (remplacer par votre domaine)
# NEXTAUTH_URL="https://votre-domaine.com"
